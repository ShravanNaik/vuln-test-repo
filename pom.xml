 <?xml version="1.0" encoding="UTF-8"?>
  <project xmlns="http://maven.apache.org/POM/4.0.0"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.example</groupId>
    <artifactId>vuln-compat-test-app</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>

    <properties>
      <!-- Java 11 — intentionally older to expose compat warnings -->
      <java.version>11</java.version>
      <maven.compiler.source>11</maven.compiler.source>
      <maven.compiler.target>11</maven.compiler.target>
      <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <dependencies>

      <!--
        CVE-2021-44228 — Log4Shell — CRITICAL
        Safe fix: 2.17.1
        Compat note: 2.17.1 still supports Java 8+, no compat issue
      -->
      <dependency>
        <groupId>org.apache.logging.log4j</groupId>
        <artifactId>log4j-core</artifactId>
        <version>2.14.1</version>
      </dependency>

      <!--
        CVE-2022-42889 — Text4Shell — HIGH
        Safe fix: 1.10.0
        Compat note: 1.10.0 compatible with Java 11
      -->
      <dependency>
        <groupId>org.apache.commons</groupId>
        <artifactId>commons-text</artifactId>
        <version>1.9</version>
      </dependency>

      <!--
        CVE-2022-42003 / CVE-2022-42004 — jackson-databind — HIGH
        Safe fix: 2.14.0
        COMPAT ISSUE: jackson-databind 2.14.x drops Java 8 support — requires Java 11+
        This project declares Java 11, so borderline — agent should flag the Java baseline change
      -->
      <dependency>
        <groupId>com.fasterxml.jackson.core</groupId>
        <artifactId>jackson-databind</artifactId>
        <version>2.13.3</version>
      </dependency>

      <!--
        CVE-2022-22965 — Spring4Shell — CRITICAL
        Safe fix: 5.3.18
        COMPAT ISSUE: spring-webmvc below uses 5.3.15 — bumping spring-core to 5.3.18
        while spring-webmvc stays at 5.3.15 causes a Spring version mismatch
        Agent should flag: all spring-* artifacts must align to the same version
      -->
      <dependency>
        <groupId>org.springframework</groupId>
        <artifactId>spring-core</artifactId>
        <version>5.3.17</version>
      </dependency>

      <!--
        Intentional version mismatch with spring-core above — simulates
        a real-world project where transitive Spring deps drift apart.
        When spring-core is bumped to 5.3.18, this stays at 5.3.15 → compat conflict.
      -->
      <dependency>
        <groupId>org.springframework</groupId>
        <artifactId>spring-webmvc</artifactId>
        <version>5.3.15</version>
      </dependency>

      <!--
        CVE-2022-41915 — Netty HTTP/2 header validation — MEDIUM
        Safe fix: 4.1.86.Final
        Compat note: 4.1.86.Final requires Java 8+, compatible with Java 11
      -->
      <dependency>
        <groupId>io.netty</groupId>
        <artifactId>netty-all</artifactId>
        <version>4.1.77.Final</version>
      </dependency>

      <!--
        No CVE — included to test compat checker's peer dependency analysis.
        jackson-annotations must match jackson-databind major.minor exactly.
        When jackson-databind is bumped to 2.14.x, this 2.13.x stays behind → conflict.
      -->
      <dependency>
        <groupId>com.fasterxml.jackson.core</groupId>
        <artifactId>jackson-annotations</artifactId>
        <version>2.13.1</version>
      </dependency>

    </dependencies>

    <build>
      <plugins>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-compiler-plugin</artifactId>
          <version>3.10.1</version>
          <configuration>
            <source>${java.version}</source>
            <target>${java.version}</target>
          </configuration>
        </plugin>
      </plugins>
    </build>

  </project>
